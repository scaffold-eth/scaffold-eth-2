{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "composite": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", ".ponder", "generated"]
}
