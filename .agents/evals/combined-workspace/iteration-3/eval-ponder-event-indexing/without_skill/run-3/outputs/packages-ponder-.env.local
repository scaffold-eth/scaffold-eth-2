# Ponder environment variables

# RPC URL for the local Hardhat network
PONDER_RPC_URL_1=http://127.0.0.1:8545

# Contract address for YourContract (update after running `yarn deploy`)
# Default is the first contract address deployed by Hardhat
PONDER_YOUR_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
